{
  "Smited": {
    "BindAddress": "0.0.0.0",
    "Backends": {
      // Default behaviour in Development matches Production: an empty
      // Items array lets the bootstrapper synthesize a mock-owo
      // descriptor at startup. Sample descriptors do NOT belong here:
      // .NET configuration merges array children by index across
      // sources, so a sample Items[1] in this file would leak into
      // user configs that supply only Items[0] (the user gets ghost
      // entries at indexes the layered Development file populated).
      // Recipes for "real OWO only", "mock + real OWO", and the
      // disabled-spare pattern live in docs/running.md and belong in
      // the user config file (~/.config/smited/config.json or
      // %APPDATA%\smited\config.json), not in this layer.
      "Items": []
    }
  },
  "Serilog": {
    "MinimumLevel": "Debug"
  }
}
