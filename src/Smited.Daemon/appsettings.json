{
  "Smited": {
    "GrpcPort": 7777,
    "PanicPort": 7778,
    "BindAddress": "127.0.0.1",
    "EnableReflection": true,
    "Backends": {
      "EnableMockOwo": true,
      "EnableOwo": false,
      "EnableMockBhaptics": false,
      "EnableBhaptics": false
    },
    "Sensations": {
      "LibraryRoot": "./sensations",
      "WatchForChanges": false
    },
    "EventBus": {
      "BufferCapacity": 1024,
      "SlowSubscriberPolicy": "drop_oldest"
    },
    "Bhaptics": {
      "BackendId": "bhaptics-primary",
      "PlayerEndpoint": "ws://localhost:15881/v2/feedbacks",
      "MaxReconnectAttempts": 3
    }
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/smited-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  }
}
