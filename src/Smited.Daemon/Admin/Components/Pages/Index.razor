@page "/"
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject BackendRegistry Registry

@*  smited admin — single page. Sections top-to-bottom:
      1. Header (status / uptime / ports)
      2. Backends (one BackendCard per registered backend)
      3. Sensation tester
      4. Recent triggers
      5. Panic button (Esc keybind dispatches via JS interop)

    The Esc shortcut goes through admin.js + DotNetObjectReference
    rather than @onkeydown on a wrapper div. Razor keyboard handlers
    fire only when the bound element has focus; after page load focus
    is on body, so a wrapper-div binding never received Esc unless
    the user clicked the wrapper first. Document-level JS listener
    works regardless.  *@

<Header />

<h2>Backends</h2>
@foreach (var backend in Registry.All)
{
    <BackendCard Backend="@backend" />
}

<SensationTester />

<RecentTriggers />

<PanicButton @ref="_panic" />

@code {
    private PanicButton? _panic;
    private DotNetObjectReference<Index>? _selfRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // OnAfterRenderAsync(firstRender:true) only fires after
            // the SignalR connection is established (not during
            // ServerPrerendered's initial render), so IJSRuntime is
            // safe to invoke here.
            _selfRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync(
                "smitedAdmin.registerKeyboardShortcuts",
                _selfRef);
        }
    }

    /// <summary>
    /// Invoked from <c>admin.js</c> when Esc is pressed anywhere on
    /// the document. Dispatches to the panic button's handler so the
    /// shortcut and the button click share one code path.
    /// </summary>
    [JSInvokable]
    public async Task OnEscapePressed()
    {
        if (_panic is not null)
        {
            await _panic.FirePanicFromKeyboard();
        }
    }

    public ValueTask DisposeAsync()
    {
        _selfRef?.Dispose();
        return ValueTask.CompletedTask;
    }
}
