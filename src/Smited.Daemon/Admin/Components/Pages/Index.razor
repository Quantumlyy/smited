@page "/"
@inject BackendRegistry Registry

@*  smited admin — single page. Sections top-to-bottom:
      1. Header (status / uptime / ports)
      2. Backends (one BackendCard per registered backend)
      3. Sensation tester
      4. Panic button (Esc keybind dispatches to its handler)
    Recent triggers panel appears in A3.  *@

<div @onkeydown="OnKeyDown" tabindex="0">
    <Header />

    <h2>Backends</h2>
    @foreach (var backend in Registry.All)
    {
        <BackendCard Backend="@backend" />
    }

    <SensationTester />

    <RecentTriggers />

    <PanicButton @ref="_panic" />
</div>

@code {
    private PanicButton? _panic;

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape" && _panic is not null)
        {
            await _panic.FirePanicFromKeyboard();
        }
    }
}
