@using RegisteredSensation = Smited.Daemon.Sensations.RegisteredSensation
@inject BackendRegistry Registry
@inject SensationLibrary Sensations
@inject TriggerCoordinator Coordinator

@*  Sensation tester. Pick backend → pick sensation → FIRE. Result line
    shows accepted=true/false plus error info on rejection. Constructs
    ResolvedTriggerInput in-process and calls TriggerCoordinator.TriggerAsync
    directly (mirrors what SmitedGrpcService does via ProtoMappers).  *@

<section class="card">
    <h2>Sensation tester</h2>

    <div style="display:flex;gap:0.5rem;flex-wrap:wrap;align-items:end">
        <div>
            <label>Backend</label><br />
            <select @bind="_selectedBackendId" @bind:after="OnBackendChanged">
                @foreach (var backend in Registry.All)
                {
                    <option value="@backend.Id">@backend.Id (@backend.Kind)</option>
                }
            </select>
        </div>

        <div>
            <label>Sensation</label><br />
            <select @bind="_selectedSensationName">
                @foreach (var sensation in _sensations)
                {
                    <option value="@sensation.Name">@sensation.Name — @sensation.DisplayName</option>
                }
            </select>
        </div>

        <details style="margin-left:1rem">
            <summary style="cursor:pointer;color:var(--muted)">Overrides</summary>
            <div style="display:flex;gap:1rem;margin-top:0.5rem">
                <label>
                    Intensity scale (%): <input type="number" min="0" max="200" step="1" @bind="_intensityScalePct" style="width:5rem" />
                </label>
                <label>
                    Priority: <input type="number" @bind="_priority" style="width:4rem" />
                </label>
                <label>
                    Trace ID: <input type="text" @bind="_traceId" style="width:18rem" />
                </label>
            </div>
        </details>

        <button class="btn-primary" @onclick="Fire" disabled="@string.IsNullOrEmpty(_selectedSensationName)">FIRE</button>
    </div>

    @if (_lastResult is not null)
    {
        <pre style="margin-top:1rem;white-space:pre-wrap;color:@(_lastResult.Accepted ? "var(--ok)" : "var(--err)")">@_lastResult.Text</pre>
    }
</section>

@code {
    private string? _selectedBackendId;
    private string? _selectedSensationName;
    private uint _intensityScalePct = 100;
    private int _priority;
    private string _traceId = Guid.NewGuid().ToString("n");
    private IReadOnlyList<RegisteredSensation> _sensations = Array.Empty<RegisteredSensation>();
    private FireResult? _lastResult;

    protected override void OnInitialized()
    {
        _selectedBackendId = Registry.All.FirstOrDefault()?.Id;
        ReloadSensations();
        _selectedSensationName = _sensations.FirstOrDefault()?.Name;
    }

    private void OnBackendChanged()
    {
        ReloadSensations();
        _selectedSensationName = _sensations.FirstOrDefault()?.Name;
    }

    private void ReloadSensations()
    {
        _sensations = string.IsNullOrEmpty(_selectedBackendId)
            ? Array.Empty<RegisteredSensation>()
            : Sensations.List(_selectedBackendId, tags: null);
    }

    private async Task Fire()
    {
        if (string.IsNullOrEmpty(_selectedBackendId) || string.IsNullOrEmpty(_selectedSensationName))
            return;

        var input = new ResolvedTriggerInput(
            BackendId: _selectedBackendId,
            SensationName: _selectedSensationName,
            InlineMicrosensations: null,
            ZoneIds: Array.Empty<string>(),
            IntensityScale: _intensityScalePct,
            Priority: _priority,
            ClientTraceId: string.IsNullOrEmpty(_traceId) ? Guid.NewGuid().ToString("n") : _traceId);

        try
        {
            var outcome = await Coordinator.TriggerAsync(input, default);
            _lastResult = outcome switch
            {
                TriggerOutcome.Accepted a =>
                    new FireResult(true,
                        $"accepted=true sensation_id={a.SensationId} trace={a.ClientTraceId} zones=[{string.Join(",", a.ResolvedZoneIds)}] intensity={a.ResolvedIntensityScale}"),
                TriggerOutcome.Rejected r =>
                    new FireResult(false,
                        $"accepted=false code={r.Code} field={r.Field ?? "<none>"} message={r.Message}"),
                _ => new FireResult(false, $"unexpected outcome: {outcome.GetType().Name}"),
            };
        }
        catch (Exception ex)
        {
            _lastResult = new FireResult(false, $"exception: {ex.GetType().Name}: {ex.Message}");
        }

        // Roll the trace ID after each fire so the next press uses a fresh
        // value unless the user typed one in.
        _traceId = Guid.NewGuid().ToString("n");
    }

    private sealed record FireResult(bool Accepted, string Text);
}
