@inject TriggerCoordinator Coordinator
@inject PanicCounter PanicCounter
@inject ILogger<PanicButton> Logger

@*  Big red panic button. Calls TriggerCoordinator.StopAsync with All=true —
    the same code path /panic uses. Press Esc on the page (handler in
    Index.razor) to fire the same handler.  *@

<section style="text-align:center;margin:2rem 0">
    <button class="btn-danger" @onclick="FirePanic">PANIC — STOP ALL</button>
    <div style="margin-top:0.5rem;color:var(--muted);font-size:0.85rem">
        Panic fired @PanicCounter.Count time@(PanicCounter.Count == 1 ? "" : "s") this session
    </div>
</section>

@code {
    public async Task FirePanicFromKeyboard() => await FirePanic();

    private async Task FirePanic()
    {
        try
        {
            await Coordinator.StopAsync(new BackendStopRequest(SensationId: null, All: true), default);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Admin panic-button stop failed");
        }
        PanicCounter.Increment();
        StateHasChanged();
    }
}
