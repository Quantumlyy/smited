<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Smited.Build</RootNamespace>
    <AssemblyName>Smited.Build</AssemblyName>
    <!-- The Cake build harness intentionally has no XML doc / nullable
         analyzer pressure; it's tooling, not a shipped library. -->
    <NoWarn>$(NoWarn);CA1050</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Cake.Frosting" />
  </ItemGroup>

</Project>
